    "No on-device recognition language available. Open recognition settings and check your dictation languages.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No on-device recognition language available. Open recognition settings and check your dictation languages."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет доступного локального языка распознавания. Откройте настройки распознавания и проверьте языки диктовки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Немає доступної мови розпізнавання на пристрої. Відкрийте налаштування розпізнавання й перевірте мови диктування."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No hay ningún idioma de reconocimiento disponible en el dispositivo. Abre los ajustes de reconocimiento y comprueba tus idiomas de dictado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aucune langue de reconnaissance disponible sur l'appareil. Ouvrez les réglages de reconnaissance et vérifiez vos langues de dictée."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Keine On-Device-Erkennungssprache verfügbar. Öffne die Erkennungseinstellungen und prüfe deine Diktiersprachen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nessuna lingua di riconoscimento sul dispositivo disponibile. Apri le impostazioni di riconoscimento e controlla le lingue di dettatura."
