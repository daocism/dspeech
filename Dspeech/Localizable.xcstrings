    "Dspeech doesn't transmit on air or send anything over the radio. The app only listens and shows text.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dspeech doesn't transmit on air or send anything over the radio. The app only listens and shows text."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Dspeech не выходит в эфир и ничего не передаёт по радио. Приложение только слушает и показывает текст."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech не виходить в ефір і нічого не передає по радіо. Застосунок лише слухає й показує текст."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech no transmite por radio ni envía nada por las ondas. La app solo escucha y muestra texto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech n'émet rien sur les ondes ni par radio. L'app se contente d'écouter et d'afficher du texte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech sendet nicht auf Frequenz und überträgt nichts per Funk. Die App hört nur zu und zeigt Text an."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech non trasmette via radio né invia nulla. L'app si limita ad ascoltare e mostrare il testo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O Dspeech não transmite no ar nem envia nada pela rádio. A app apenas escuta e mostra texto."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech 不会在空中发射或通过无线电发送任何内容。本应用只聆听并显示文本。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeechは送信や無線への送出を一切行いません。アプリは受信してテキストを表示するだけです。"
          }
        }
      }
    },
    "Dspeech processes audio locally only. Audio never leaves your device.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dspeech processes audio locally only. Audio never leaves your device."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Dspeech обрабатывает звук только локально. Аудио не покидает устройство."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech обробляє аудіо лише локально. Аудіо ніколи не залишає ваш пристрій."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech procesa el audio solo de forma local. El audio nunca sale de tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech traite l'audio uniquement en local. L'audio ne quitte jamais votre appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech verarbeitet Audio ausschließlich lokal. Audio verlässt nie dein Gerät."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech elabora l'audio solo in locale. L'audio non lascia mai il dispositivo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O Dspeech processa o áudio apenas localmente. O áudio nunca sai do seu dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeech 仅在本地处理音频。音频绝不离开您的设备。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Dspeechは音声を端末内のみで処理します。音声が端末外に出ることはありません。"
          }
        }
      }
    },
