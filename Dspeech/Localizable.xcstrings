    "No input source detected. Connect a wired input (USB-C / TRRS) or use the built-in microphone.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Keine Eingangsquelle erkannt. Schließe einen kabelgebundenen Eingang an (USB-C / TRRS) oder nutze das integrierte Mikrofon."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No input source detected. Connect a wired input (USB-C / TRRS) or use the built-in microphone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No se detectó ninguna fuente de entrada. Conecta una entrada con cable (USB-C / TRRS) o usa el micrófono integrado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aucune source d'entrée détectée. Branchez une entrée filaire (USB-C / TRRS) ou utilisez le microphone intégré."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nessuna sorgente di ingresso rilevata. Collega un ingresso cablato (USB-C / TRRS) o usa il microfono integrato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "入力ソースが検出されません。有線入力（USB-C / TRRS）を接続するか、内蔵マイクを使用してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "입력 소스가 감지되지 않았습니다. 유선 입력(USB-C / TRRS)을 연결하거나 내장 마이크를 사용하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nenhuma fonte de entrada detetada. Ligue uma entrada com fio (USB-C / TRRS) ou use o microfone integrado."
          }
        },
        "ru": {
          "stringUnit": {
