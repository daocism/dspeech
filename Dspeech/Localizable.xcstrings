            "state": "translated",
            "value": "Voice filter off. The model is installed and ready."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Голосовой фильтр выключен. Модель установлена и готова к работе."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Голосовий фільтр вимкнено. Модель встановлено й готову."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filtro de voz desactivado. El modelo está instalado y listo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
