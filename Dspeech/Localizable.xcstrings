    "Запрос доступа к микрофону и распознаванию речи…": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запрос доступа к микрофону и распознаванию речи…"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Requesting microphone and speech recognition access…"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запит доступу до мікрофона та розпізнавання мовлення…"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitando acceso al micrófono y al reconocimiento de voz…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demande d’accès au micro et à la reconnaissance vocale…"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zugriff auf Mikrofon und Spracherkennung wird angefragt…"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Richiesta di accesso a microfono e riconoscimento vocale…"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Solicitando acesso ao microfone e ao reconhecimento de fala…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在请求麦克风和语音识别权限…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクと音声認識へのアクセスを要求中…"
          }
        }
      }
    },
    "Нажмите «Старт» и говорите — расшифровка появится здесь.\nЛокальная обработка, аудио не покидает устройство.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите «Старт» и говорите — расшифровка появится здесь.\nЛокальная обработка, аудио не покидает устройство."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Start and speak — the transcript appears here.\nProcessed on device; audio never leaves your iPhone."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Натисніть «Старт» і говоріть — розшифровка з’явиться тут.\nОбробка на пристрої, аудіо не залишає iPhone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca Iniciar y habla: la transcripción aparece aquí.\nProcesado en el dispositivo; el audio no sale del iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez Démarrer et parlez — la transcription apparaît ici.\nTraitement sur l’appareil ; l’audio ne quitte pas l’iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf Start und sprich — das Transkript erscheint hier.\nVerarbeitung auf dem Gerät; Audio verlässt das iPhone nicht."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca Avvia e parla: la trascrizione appare qui.\nElaborazione sul dispositivo; l’audio non lascia l’iPhone."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em Iniciar e fale — a transcrição aparece aqui.\nProcessado no dispositivo; o áudio não sai do iPhone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按“开始”并说话——转写文字会显示在这里。\n在设备上处理，音频不会离开 iPhone。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「開始」をタップして話すと、ここに文字起こしが表示されます。\n端末内で処理され、音声は iPhone から出ません。"
          }
        }
      }
    },
