    "Audio capture stopped, but iOS couldn't release the audio session. Check the input before starting again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Audioaufnahme wurde gestoppt, aber iOS konnte die Audiositzung nicht freigeben. Prüfen Sie den Eingang vor dem Neustart."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio capture stopped, but iOS couldn't release the audio session. Check the input before starting again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La captura de audio se detuvo, pero iOS no pudo liberar la sesión de audio. Revise la entrada antes de volver a iniciar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La capture audio s’est arrêtée, mais iOS n’a pas pu libérer la session audio. Vérifiez l’entrée avant de relancer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cattura audio si è fermata, ma iOS non ha potuto rilasciare la sessione audio. Controlla l’ingresso prima di ripartire."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声キャプチャは停止しましたが、iOS が音声セッションを解放できませんでした。再開前に入力を確認してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오디오 캡처는 중지됐지만 iOS가 오디오 세션을 해제하지 못했습니다. 다시 시작하기 전에 입력을 확인하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A captura de áudio parou, mas o iOS não conseguiu liberar a sessão de áudio. Verifique a entrada antes de iniciar novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
