    "The saved state of the voice model pack is corrupted. Continue without the voice filter and re-download the pack if needed.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Der gespeicherte Zustand des Stimmmodell-Pakets ist beschädigt. Fahre ohne Stimmfilter fort und lade das Paket bei Bedarf erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The saved state of the voice model pack is corrupted. Continue without the voice filter and re-download the pack if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El estado guardado del paquete del modelo de voz está dañado. Continúa sin el filtro de voz y vuelve a descargar el paquete si es necesario."
