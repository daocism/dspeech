          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Campione vocale registrato. Registra di nuovo per aggiornarlo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Amostra de voz gravada. Grave novamente para a atualizar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "已录制语音样本。再次录制可更新。"
