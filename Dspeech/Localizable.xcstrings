    "Too quiet or too short — record a clearer sample.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too quiet or too short — record a clearer sample."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слишком тихо или коротко — запишите образец чётче."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Надто тихо або надто коротко — запишіть чіткіший зразок."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Demasiado bajo o demasiado corto: graba una muestra más clara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Trop faible ou trop court — enregistrez un échantillon plus clair."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Zu leise oder zu kurz — nimm eine deutlichere Probe auf."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Troppo debole o troppo breve — registra un campione più chiaro."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Demasiado baixo ou demasiado curto — grave uma amostra mais nítida."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "太轻或太短——请录制更清晰的样本。"
          }
