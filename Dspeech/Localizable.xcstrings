            "value": "Stimmfilter aus. Das Modell ist installiert und bereit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filtro voce disattivato. Il modello è installato e pronto."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Filtro de voz desligado. O modelo está instalado e pronto."
          }
        },
