    "The saved callsign is corrupted. Reset it and set the callsign again.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Das gespeicherte Rufzeichen ist beschädigt. Setze es zurück und lege das Rufzeichen erneut fest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The saved callsign is corrupted. Reset it and set the callsign again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El indicativo guardado está dañado. Restablécelo y vuelve a definir el indicativo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
