    "Couldn't delete the model pack from the device. Check storage access and try again later.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Das Modellpaket konnte nicht vom Gerät gelöscht werden. Prüfe den Speicherzugriff und versuche es später erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't delete the model pack from the device. Check storage access and try again later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No se pudo eliminar el paquete del modelo del dispositivo. Comprueba el acceso al almacenamiento e inténtalo más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossible de supprimer le pack du modèle de l'appareil. Vérifiez l'accès au stockage et réessayez plus tard."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossibile eliminare il pacchetto del modello dal dispositivo. Controlla l'accesso allo spazio di archiviazione e riprova più tardi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "端末からモデルパックを削除できませんでした。ストレージへのアクセスを確認して後でもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "기기에서 모델 팩을 삭제할 수 없습니다. 저장소 접근을 확인하고 나중에 다시 시도하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Não foi possível eliminar o pacote do modelo do dispositivo. Verifique o acesso ao armazenamento e tente novamente mais tarde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось удалить пакет модели с устройства. Проверьте доступ к хранилищу и попробуйте позже."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не вдалося видалити пакет моделі з пристрою. Перевірте доступ до сховища та спробуйте пізніше."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "无法从设备删除模型包。请检查存储权限并稍后重试。"
          }
        }
      }
    },
    "Couldn't delete the model pack from the device. The device reported a storage or file-access error. Try again later.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Modellpaket konnte nicht vom Gerät gelöscht werden. Das Gerät meldete einen Speicher- oder Dateizugriffsfehler. Versuchen Sie es später erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't delete the model pack from the device. The device reported a storage or file-access error. Try again later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo borrar el paquete del modelo del dispositivo. El dispositivo informó un error de almacenamiento o acceso a archivos. Inténtelo más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de supprimer le pack de modèle de l’appareil. L’appareil a signalé une erreur de stockage ou d’accès aux fichiers. Réessayez plus tard."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile eliminare il pacchetto modello dal dispositivo. Il dispositivo ha segnalato un errore di archiviazione o di accesso ai file. Riprova più tardi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイスからモデルパックを削除できませんでした。ストレージまたはファイルアクセスのエラーが報告されました。後でもう一度試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기에서 모델 팩을 삭제할 수 없습니다. 기기가 저장 공간 또는 파일 접근 오류를 보고했습니다. 나중에 다시 시도하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
