    "Tap Start and speak — the transcript will appear here.\nProcessed locally; audio never leaves your device.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Start and speak — the transcript will appear here.\nProcessed locally; audio never leaves your device."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите «Старт» и говорите — расшифровка появится здесь.\nЛокальная обработка, аудио не покидает устройство."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Натисніть «Старт» і говоріть — транскрипт зʼявиться тут.\nОбробка локальна; аудіо ніколи не залишає ваш пристрій."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pulsa Iniciar y habla; la transcripción aparecerá aquí.\nProcesado localmente; el audio nunca sale de tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Appuyez sur Démarrer et parlez — la transcription apparaîtra ici.\nTraitement local ; l'audio ne quitte jamais votre appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Auf Start tippen und sprechen — das Transkript erscheint hier.\nVerarbeitung lokal; Audio verlässt nie dein Gerät."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Tocca Avvia e parla — la trascrizione apparirà qui.\nElaborazione in locale; l'audio non lascia mai il dispositivo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Toque em Iniciar e fale — a transcrição aparecerá aqui.\nProcessado localmente; o áudio nunca sai do seu dispositivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "点击开始并讲话——转写文本将在此显示。\n本地处理；音频绝不离开您的设备。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "開始をタップして話してください — ここに文字起こしが表示されます。\nすべて端末内で処理され、音声が端末外に出ることはありません。"
          }
        }
      }
    },
