    "Use the built-in microphone to try it out. For the cockpit, connect a wired input (USB-C / TRRS).": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the built-in microphone to try it out. For the cockpit, connect a wired input (USB-C / TRRS)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Встроенный микрофон — чтобы попробовать. Для кокпита подключите проводной вход (USB-C / TRRS)."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Скористайтеся вбудованим мікрофоном, щоб спробувати. Для кабіни підключіть провідний вхід (USB-C / TRRS)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Usa el micrófono integrado para probarlo. Para la cabina, conecta una entrada con cable (USB-C / TRRS)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Utilisez le microphone intégré pour faire un essai. Pour le cockpit, branchez une entrée filaire (USB-C / TRRS)."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Nutze das integrierte Mikrofon zum Ausprobieren. Für das Cockpit schließe einen kabelgebundenen Eingang an (USB-C / TRRS)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Usa il microfono integrato per provarlo. In cabina, collega un ingresso cablato (USB-C / TRRS)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Use o microfone integrado para experimentar. Para o cockpit, ligue uma entrada com fio (USB-C / TRRS)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "使用内置麦克风即可试用。座舱中请连接有线输入（USB-C / TRRS）。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "内蔵マイクでお試しください。コックピットでは有線入力（USB-C / TRRS）を接続してください。"
          }
        }
      }
    },
