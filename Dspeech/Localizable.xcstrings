    "Listening -- spell out the callsign (for example: \"november one two three alpha bravo\").": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Hört zu -- buchstabiere das Rufzeichen (zum Beispiel: \"november one two three alpha bravo\")."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Listening -- spell out the callsign (for example: \"november one two three alpha bravo\")."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Escuchando -- deletree el indicativo (por ejemplo: \"november one two three alpha bravo\")."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Écoute -- épelez l’indicatif (par exemple : \"november one two three alpha bravo\")."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "In ascolto -- scandisci il nominativo (per esempio: \"november one two three alpha bravo\")."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "聞き取り中 -- コールサインを綴ってください（例: \"november one two three alpha bravo\"）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "듣는 중 -- 콜사인을 철자로 말하세요(예: \"november one two three alpha bravo\")."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ouvindo -- soletre o indicativo (por exemplo: \"november one two three alpha bravo\")."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Слушаю -- произнесите позывной по буквам (например: \"november one two three alpha bravo\")."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Слухаю -- промовте позивний по літерах (наприклад: \"november one two three alpha bravo\")."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "正在听取 -- 请拼读呼号（例如：“november one two three alpha bravo”）。"
          }
        }
      }
    },
