    "Audio input changed and recognition couldn't recover. Check the input and start again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Audioeingang hat sich geändert und die Erkennung konnte sich nicht erholen. Prüfen Sie den Eingang und starten Sie erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio input changed and recognition couldn't recover. Check the input and start again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La entrada de audio cambió y el reconocimiento no pudo recuperarse. Revise la entrada e inicie de nuevo."
