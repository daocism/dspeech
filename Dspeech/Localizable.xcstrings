    "Confident pilot speech can be stopped before recognition. Callsign relevance filtering stays active separately.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sicher erkannte Pilotenansagen können vor der Erkennung gestoppt werden. Die Rufzeichen-Relevanzfilterung bleibt separat aktiv."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confident pilot speech can be stopped before recognition. Callsign relevance filtering stays active separately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La voz del piloto identificada con confianza puede detenerse antes del reconocimiento. El filtro de relevancia del indicativo sigue activo por separado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La voix pilote reconnue avec confiance peut être arrêtée avant la reconnaissance. Le filtrage de pertinence de l'indicatif reste actif séparément."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "La voce pilota riconosciuta con sicurezza può essere fermata prima del riconoscimento. Il filtro di rilevanza del nominativo resta attivo separatamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "高い確度のパイロット音声は認識前に止められます。コールサイン関連性フィルタは別に有効のままです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "확실한 파일럿 음성은 인식 전에 중단할 수 있습니다. 콜사인 관련성 필터링은 별도로 활성 상태를 유지합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "A fala do piloto identificada com confiança pode ser bloqueada antes do reconhecimento. O filtro de relevância do indicativo continua ativo separadamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уверенно распознанная речь пилота может останавливаться до распознавания. Фильтр релевантности позывного работает отдельно."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Упевнено розпізнану мову пілота можна зупиняти до розпізнавання. Фільтр релевантності позивного працює окремо."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "高置信度的飞行员语音可在识别前停止。呼号相关性过滤会单独保持启用。"
          }
        }
      }
    },
