    "Not enough voiced speech. Speak clearly for at least %@ seconds and try again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht genug gesprochene Sprache. Sprechen Sie mindestens %@ Sekunden klar und versuchen Sie es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not enough voiced speech. Speak clearly for at least %@ seconds and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay suficiente voz. Hable con claridad durante al menos %@ segundos e inténtelo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas assez de parole audible. Parlez clairement pendant au moins %@ secondes et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Voce insufficiente. Parla chiaramente per almeno %@ secondi e riprova."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有声音声が不足しています。少なくとも %@ 秒はっきり話して、もう一度試してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유성 음성이 부족합니다. 최소 %@초 동안 또렷하게 말한 뒤 다시 시도하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há fala suficiente. Fale claramente por pelo menos %@ segundos e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно звучащей речи. Говорите чётко не менее %@ секунд и попробуйте снова."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостатньо звучного мовлення. Говоріть чітко щонайменше %@ секунд і спробуйте знову."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "有声语音不足。请清晰说话至少 %@ 秒，然后重试。"
          }
        }
      }
    },
