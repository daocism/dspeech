    "The saved callsign is corrupted. Reset it and set the callsign again.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The saved callsign is corrupted. Reset it and set the callsign again."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранённый позывной повреждён. Сбросьте его и задайте позывной заново."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Збережений позивний пошкоджено. Скиньте його й задайте позивний знову."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El indicativo guardado está dañado. Restablécelo y vuelve a definir el indicativo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "L'indicatif enregistré est corrompu. Réinitialisez-le et redéfinissez l'indicatif."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Das gespeicherte Rufzeichen ist beschädigt. Setze es zurück und lege das Rufzeichen erneut fest."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Il nominativo salvato è danneggiato. Ripristinalo e imposta di nuovo il nominativo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O indicativo guardado está corrompido. Reponha-o e defina o indicativo novamente."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "已保存的呼号已损坏。请重置并重新设置呼号。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "保存されたコールサインが破損しています。リセットしてコールサインを設定し直してください。"
          }
        }
      }
    },
    "The saved state of the voice model pack is corrupted. Continue without the voice filter and re-download the pack if needed.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The saved state of the voice model pack is corrupted. Continue without the voice filter and re-download the pack if needed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранённое состояние пакета голосовой модели повреждено. Продолжите без голосового фильтра и при необходимости скачайте пакет заново."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Збережений стан пакета голосової моделі пошкоджено. Продовжте без голосового фільтра й за потреби завантажте пакет знову."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El estado guardado del paquete del modelo de voz está dañado. Continúa sin el filtro de voz y vuelve a descargar el paquete si es necesario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "L'état enregistré du pack du modèle vocal est corrompu. Continuez sans le filtre de voix et retéléchargez le pack si nécessaire."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Der gespeicherte Zustand des Stimmmodell-Pakets ist beschädigt. Fahre ohne Stimmfilter fort und lade das Paket bei Bedarf erneut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lo stato salvato del pacchetto del modello vocale è danneggiato. Continua senza filtro voce e riscarica il pacchetto se necessario."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O estado guardado do pacote do modelo de voz está corrompido. Continue sem o filtro de voz e volte a descarregar o pacote se necessário."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "语音模型包的已保存状态已损坏。请不使用语音过滤继续，并在需要时重新下载该包。"
