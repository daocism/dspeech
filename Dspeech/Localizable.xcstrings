    "Couldn't get microphone and speech access. Check the permissions in iPhone Settings, then tap Start again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't get microphone and speech access. Check the permissions in iPhone Settings, then tap Start again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Kein Zugriff auf Mikrofon und Spracherkennung. Prüfe die Berechtigungen in den iPhone-Einstellungen und tippe dann erneut auf Start."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No se pudo acceder al micrófono ni al reconocimiento de voz. Revisa los permisos en Ajustes del iPhone y vuelve a tocar Iniciar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossible d’accéder au micro et à la reconnaissance vocale. Vérifiez les autorisations dans les Réglages de l’iPhone, puis touchez de nouveau Démarrer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossibile accedere a microfono e riconoscimento vocale. Controlla le autorizzazioni in Impostazioni iPhone, poi tocca di nuovo Avvia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "マイクと音声認識へのアクセスを取得できませんでした。iPhoneの設定で権限を確認し、もう一度「開始」をタップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "마이크 및 음성 인식 접근 권한을 얻지 못했습니다. iPhone 설정에서 권한을 확인한 후 다시 시작을 누르세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Não foi possível acessar o microfone e o reconhecimento de fala. Verifique as permissões nos Ajustes do iPhone e toque em Iniciar novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не удалось получить доступ к микрофону и распознаванию речи. Проверьте разрешения в Настройках iPhone и снова нажмите «Старт»."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не вдалося отримати доступ до мікрофона та розпізнавання мовлення. Перевірте дозволи в Налаштуваннях iPhone і знову натисніть «Старт»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "无法访问麦克风和语音识别。请在 iPhone 设置中检查权限,然后再次点按“开始”。"
          }
        }
      }
    },
    "Didn't catch enough of your voice. Speak for about 5 seconds in a quiet spot, then tap Stop.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Didn't catch enough of your voice. Speak for about 5 seconds in a quiet spot, then tap Stop."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Stimme nicht ausreichend erfasst. Sprich etwa 5 Sekunden an einem ruhigen Ort und tippe dann auf Stopp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "No se captó suficiente tu voz. Habla unos 5 segundos en un lugar tranquilo y luego toca Detener."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Voix pas assez captée. Parlez environ 5 secondes dans un endroit calme, puis touchez Arrêter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Voce non sufficiente. Parla per circa 5 secondi in un luogo tranquillo, poi tocca Stop."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "声を十分に聞き取れませんでした。静かな場所で約5秒話してから「停止」をタップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "목소리를 충분히 듣지 못했습니다. 조용한 곳에서 약 5초간 말한 후 정지를 누르세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Não captei sua voz o suficiente. Fale por cerca de 5 segundos num local silencioso e toque em Parar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не удалось записать достаточно голоса. Говорите около 5 секунд в тихом месте, затем нажмите «Стоп»."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не вдалося записати достатньо голосу. Говоріть близько 5 секунд у тихому місці, потім натисніть «Стоп»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "没有录到足够的语音。请在安静处说约5秒,然后点按“停止”。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
