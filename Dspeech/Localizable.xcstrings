          "Recognition runs on-device only. Audio and voice samples never leave your device. See ADR 0007 and ADR 0008 for details.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Recognition runs on-device only. Audio and voice samples never leave your device. See ADR 0007 and ADR 0008 for details."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Распознавание выполняется только на устройстве. Аудио и образцы голоса не покидают устройство. Подробности: ADR 0007 и ADR 0008."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Розпізнавання виконується лише на пристрої. Аудіо й зразки голосу не залишають пристрій. Деталі: ADR 0007 і ADR 0008."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "El reconocimiento se ejecuta solo en el dispositivo. El audio y las muestras de voz nunca salen del dispositivo. Consulte ADR 0007 y ADR 0008."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La reconnaissance s'exécute uniquement sur l'appareil. L'audio et les échantillons vocaux ne quittent jamais l'appareil. Voir ADR 0007 et ADR 0008."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Erkennung läuft nur auf dem Gerät. Audio und Stimmproben verlassen das Gerät nie. Details in ADR 0007 und ADR 0008."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Il riconoscimento avviene solo sul dispositivo. Audio e campioni vocali non lasciano mai il dispositivo. Vedi ADR 0007 e ADR 0008."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "O reconhecimento roda apenas no dispositivo. Áudio e amostras de voz nunca saem do dispositivo. Veja ADR 0007 e ADR 0008."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "识别仅在设备上运行。音频和语音样本绝不会离开设备。详情见 ADR 0007 和 ADR 0008。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "認識はデバイス上だけで実行されます。音声と音声サンプルはデバイス外へ送信されません。詳細は ADR 0007 と ADR 0008 を参照してください。"
                        }
                  }
            }
      },
          "Listening -- spell out the callsign (for example: \"november one two three alpha bravo\").": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Listening -- spell out the callsign (for example: \"november one two three alpha bravo\")."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Слушаю -- произнесите позывной по буквам (например: \"november one two three alpha bravo\")."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Слухаю -- промовте позивний по літерах (наприклад: \"november one two three alpha bravo\")."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Escuchando -- deletree el indicativo (por ejemplo: \"november one two three alpha bravo\")."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Écoute -- épelez l’indicatif (par exemple : \"november one two three alpha bravo\")."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Hört zu -- buchstabiere das Rufzeichen (zum Beispiel: \"november one two three alpha bravo\")."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "In ascolto -- scandisci il nominativo (per esempio: \"november one two three alpha bravo\")."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Ouvindo -- soletre o indicativo (por exemplo: \"november one two three alpha bravo\")."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "正在听取 -- 请拼读呼号（例如：“november one two three alpha bravo”）。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "聞き取り中 -- コールサインを綴ってください（例: \"november one two three alpha bravo\"）。"
                        }
                  }
            }
      },
          "Recording -- speak for a few seconds, then tap Stop.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Recording -- speak for a few seconds, then tap Stop."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Идёт запись -- говорите несколько секунд, затем нажмите «Стоп»."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Триває запис -- говоріть кілька секунд, потім натисніть «Стоп»."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Grabando -- hable unos segundos y toque Detener."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Enregistrement -- parlez quelques secondes, puis touchez Arrêter."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Aufnahme -- sprich einige Sekunden und tippe dann auf Stopp."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Registrazione -- parla per alcuni secondi, poi tocca Stop."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Gravando -- fale por alguns segundos e toque em Parar."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "正在录制 -- 请说几秒钟，然后轻点停止。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "録音中 -- 数秒話してから停止をタップしてください。"
                        }
                  }
            }
      },
          "Recording failed -- try again.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Recording failed -- try again."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Запись не удалась -- попробуйте снова."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Не вдалося записати -- спробуйте ще раз."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La grabación falló -- inténtelo de nuevo."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "L'enregistrement a échoué -- réessayez."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Aufnahme fehlgeschlagen -- versuche es erneut."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Registrazione non riuscita -- riprova."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "A gravação falhou -- tente novamente."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "录制失败 -- 请重试。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "録音に失敗しました -- もう一度試してください。"
                        }
                  }
            }
      },
          "Too quiet or too short -- record a clearer sample.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Too quiet or too short -- record a clearer sample."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Слишком тихо или коротко -- запишите более чёткий образец."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Занадто тихо або коротко -- запишіть чіткіший зразок."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Demasiado bajo o corto -- grabe una muestra más clara."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Trop faible ou trop court -- enregistrez un échantillon plus clair."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Zu leise oder zu kurz -- nimm eine klarere Probe auf."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Troppo basso o troppo breve -- registra un campione più chiaro."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Baixo demais ou curto demais -- grave uma amostra mais clara."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "太轻或太短 -- 请录制更清晰的样本。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "小さすぎるか短すぎます -- より明瞭なサンプルを録音してください。"
                        }
                  }
            }
      },
          "The FluidAudio model (%@) is downloaded once at this request. Only the model download request leaves the device -- audio, transcripts and voice samples are not transmitted.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "The FluidAudio model (%@) is downloaded once at this request. Only the model download request leaves the device -- audio, transcripts and voice samples are not transmitted."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Модель FluidAudio (%@) загружается один раз по этому запросу. С устройства уходит только запрос загрузки модели -- аудио, транскрипты и образцы голоса не передаются."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Модель FluidAudio (%@) завантажується один раз за цим запитом. З пристрою виходить лише запит завантаження моделі -- аудіо, транскрипти й зразки голосу не передаються."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "El modelo FluidAudio (%@) se descarga una vez con esta solicitud. Solo sale del dispositivo la solicitud de descarga del modelo -- no se transmiten audio, transcripciones ni muestras de voz."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Le modèle FluidAudio (%@) se télécharge une seule fois à cette demande. Seule la demande de téléchargement du modèle quitte l'appareil -- l'audio, les transcriptions et les échantillons vocaux ne sont pas transmis."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Das FluidAudio-Modell (%@) wird auf diese Anforderung einmalig geladen. Nur die Modelldownload-Anforderung verlässt das Gerät -- Audio, Transkripte und Stimmproben werden nicht übertragen."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Il modello FluidAudio (%@) viene scaricato una volta su questa richiesta. Solo la richiesta di download del modello lascia il dispositivo -- audio, trascrizioni e campioni vocali non vengono trasmessi."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "O modelo FluidAudio (%@) é baixado uma vez a partir desta solicitação. Apenas a solicitação de download do modelo sai do dispositivo -- áudio, transcrições e amostras de voz não são transmitidos."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "FluidAudio 模型（%@）只会按此请求下载一次。只有模型下载请求会离开设备 -- 音频、转写和语音样本不会传输。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "FluidAudio モデル（%@）はこのリクエストで一度だけダウンロードされます。デバイス外へ送信されるのはモデルダウンロード要求だけです -- 音声、文字起こし、音声サンプルは送信されません。"
                        }
                  }
            }
      },
