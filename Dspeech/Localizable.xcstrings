    },
    "The translation language pack isn't installed. Turn translation off and on again — iOS will offer the download.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The translation language pack isn't installed. Turn translation off and on again — iOS will offer the download."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Языковой пакет перевода не установлен. Выключите и снова включите перевод — iOS предложит загрузку."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Мовний пакет перекладу не встановлено. Вимкніть і знову ввімкніть переклад — iOS запропонує завантаження."
          }
        },
        "es": {
