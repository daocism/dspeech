          }
        }
      }
    },
    "Voice sample recorded. Record again to update it.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice sample recorded. Record again to update it."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Образец голоса записан. Запишите заново, чтобы обновить."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Голосовий зразок записано. Запишіть знову, щоб оновити."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Muestra de voz grabada. Vuelve a grabar para actualizarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Échantillon vocal enregistré. Enregistrez à nouveau pour le mettre à jour."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
