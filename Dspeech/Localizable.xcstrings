    "The iOS audio service restarted. Recording paused — check the input and start again.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Der iOS-Audiodienst wurde neu gestartet. Aufnahme pausiert — prüfe den Eingang und starte erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The iOS audio service restarted. Recording paused — check the input and start again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El servicio de audio de iOS se reinició. Grabación en pausa: comprueba la entrada y empieza de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Le service audio d'iOS a redémarré. Enregistrement en pause — vérifiez l'entrée et recommencez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Il servizio audio di iOS è stato riavviato. Registrazione in pausa — controlla l'ingresso e ricomincia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iOSのオーディオサービスが再起動しました。録音を一時停止しました — 入力を確認してから再開してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iOS 오디오 서비스가 다시 시작되었습니다. 녹음을 일시정지했습니다 — 입력을 확인하고 다시 시작하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "O serviço de áudio do iOS foi reiniciado. Gravação em pausa — verifique a entrada e recomece."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аудиосервис iOS перезапущен. Запись приостановлена — проверьте вход и запустите снова."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Аудіослужбу iOS перезапущено. Запис призупинено — перевірте вхід і почніть знову."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "iOS 音频服务已重启。录制已暂停——请检查输入后重新开始。"
          }
        }
      }
    },
