          "Confident pilot speech can be stopped before recognition. Callsign relevance filtering stays active separately.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Confident pilot speech can be stopped before recognition. Callsign relevance filtering stays active separately."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Уверенно распознанная речь пилота может останавливаться до распознавания. Фильтр релевантности позывного работает отдельно."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Упевнено розпізнану мову пілота можна зупиняти до розпізнавання. Фільтр релевантності позивного працює окремо."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La voz del piloto identificada con confianza puede detenerse antes del reconocimiento. El filtro de relevancia del indicativo sigue activo por separado."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La voix pilote reconnue avec confiance peut être arrêtée avant la reconnaissance. Le filtrage de pertinence de l'indicatif reste actif séparément."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Sicher erkannte Pilotenansagen können vor der Erkennung gestoppt werden. Die Rufzeichen-Relevanzfilterung bleibt separat aktiv."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La voce pilota riconosciuta con sicurezza può essere fermata prima del riconoscimento. Il filtro di rilevanza del nominativo resta attivo separatamente."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "A fala do piloto identificada com confiança pode ser bloqueada antes do reconhecimento. O filtro de relevância do indicativo continua ativo separadamente."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "高置信度的飞行员语音可在识别前停止。呼号相关性过滤会单独保持启用。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "高い確度のパイロット音声は認識前に止められます。コールサイン関連性フィルタは別に有効のままです。"
                        }
                  }
            }
      },
          "Speaker classification is off; all audio buffers pass to recognition. Callsign relevance filtering can still hide irrelevant ATC.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Speaker classification is off; all audio buffers pass to recognition. Callsign relevance filtering can still hide irrelevant ATC."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Классификация голоса выключена; все аудиобуферы идут на распознавание. Фильтр позывного всё ещё может скрывать нерелевантный ATC."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Класифікацію голосу вимкнено; усі аудіобуфери йдуть на розпізнавання. Фільтр позивного все ще може приховувати нерелевантний ATC."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La clasificación de voz está desactivada; todo el audio pasa al reconocimiento. El filtro de indicativo aún puede ocultar ATC no relevante."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La classification vocale est désactivée ; tout l'audio passe à la reconnaissance. Le filtre d'indicatif peut encore masquer l'ATC non pertinent."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Die Sprecherklassifizierung ist aus; alle Audiopuffer gehen zur Erkennung. Die Rufzeichenfilterung kann weiterhin irrelevanten ATC ausblenden."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "La classificazione vocale è disattivata; tutto l’audio passa al riconoscimento. Il filtro del nominativo può ancora nascondere ATC non rilevante."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "A classificação de voz está desligada; todo o áudio segue para reconhecimento. O filtro de indicativo ainda pode ocultar ATC irrelevante."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "说话人分类已关闭；所有音频缓冲都会进入识别。呼号相关性过滤仍可隐藏无关 ATC。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "話者分類はオフです。すべての音声バッファは認識へ送られます。コールサイン関連性フィルタは無関係なATCを非表示にできます。"
                        }
                  }
            }
      },
          "Check dictation languages in device Settings. Dspeech won't fall back to cloud recognition in place of local mode.": {
            "extractionState": "manual",
            "localizations": {
                  "en": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Check dictation languages in device Settings. Dspeech won't fall back to cloud recognition in place of local mode."
                        }
                  },
                  "ru": {
                        "stringUnit": {
                              "state": "translated",
                              "value": "Проверьте языки диктовки в настройках устройства. Dspeech не заменяет локальный режим облачным распознаванием."
                        }
                  },
                  "uk": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Перевірте мови диктування в налаштуваннях пристрою. Dspeech не замінює локальний режим хмарним розпізнаванням."
                        }
                  },
                  "es": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Revise los idiomas de dictado en Ajustes del dispositivo. Dspeech no sustituye el modo local con reconocimiento en la nube."
                        }
                  },
                  "fr": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Vérifiez les langues de dictée dans les réglages de l'appareil. Dspeech ne remplace pas le mode local par la reconnaissance cloud."
                        }
                  },
                  "de": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Prüfe die Diktier-Sprachen in den Geräteeinstellungen. Dspeech ersetzt den lokalen Modus nicht durch Cloud-Erkennung."
                        }
                  },
                  "it": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Controlla le lingue di dettatura nelle impostazioni del dispositivo. Dspeech non sostituisce la modalità locale con il riconoscimento cloud."
                        }
                  },
                  "pt": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "Verifique os idiomas de ditado nos Ajustes do dispositivo. O Dspeech não troca o modo local por reconhecimento em nuvem."
                        }
                  },
                  "zh-Hans": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "请在设备设置中检查听写语言。Dspeech 不会用云端识别替代本地模式。"
                        }
                  },
                  "ja": {
                        "stringUnit": {
                              "state": "needs_review",
                              "value": "デバイス設定で音声入力言語を確認してください。Dspeech はローカルモードの代わりにクラウド認識へ切り替えません。"
                        }
                  }
            }
      },
          "Open Device Settings": {
            "extractionState": "manual",
            "localizations": {
