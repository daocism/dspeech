    "Audio and transcripts stay on this device. Nothing leaves your device.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Audio und Transkripte bleiben auf diesem Gerät. Nichts verlässt das Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio and transcripts stay on this device. Nothing leaves your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El audio y las transcripciones permanecen en este dispositivo. Nada sale del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "L'audio et les transcriptions restent sur cet appareil. Rien ne quitte l'appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Audio e trascrizioni restano su questo dispositivo. Nulla lascia il dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "音声と文字起こしはこのデバイス上に残ります。何もデバイス外へ送信されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "오디오와 전사 내용은 이 기기에 남습니다. 어떤 것도 기기를 떠나지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Áudio e transcrições ficam neste dispositivo. Nada sai do dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аудио и транскрипты остаются на этом устройстве. Ничего не покидает устройство."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Аудіо й транскрипти залишаються на цьому пристрої. Нічого не залишає пристрій."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "音频和转写保留在此设备上。不会离开设备。"
          }
        }
      }
    },
    "Audio capture is already in use. Stop transcription before recording an enrollment.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Audioaufnahme wird bereits verwendet. Stoppen Sie die Transkription vor der Stimmprobe."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio capture is already in use. Stop transcription before recording an enrollment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La captura de audio ya está en uso. Detenga la transcripción antes de grabar una muestra de inscripción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La capture audio est déjà utilisée. Arrêtez la transcription avant d’enregistrer un échantillon d’inscription."
          }
        },
        "it": {
          "stringUnit": {
