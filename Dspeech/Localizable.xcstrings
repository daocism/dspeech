    "Recording -- keep speaking for about 4 seconds, then tap Stop.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recording -- keep speaking for about 4 seconds, then tap Stop."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aufnahme – sprich etwa 4 Sekunden weiter und tippe dann auf Stopp."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Grabando: sigue hablando unos 4 segundos y luego toca Detener."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Enregistrement – continuez à parler environ 4 secondes, puis touchez Arrêter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Registrazione: continua a parlare per circa 4 secondi, poi tocca Stop."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "録音中 — 約4秒間話し続けてから「停止」をタップしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "녹음 중 — 약 4초간 계속 말한 후 정지를 누르세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Gravando: continue falando por cerca de 4 segundos e toque em Parar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Запись — говорите ещё около 4 секунд, затем нажмите «Стоп»."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Запис — говоріть ще близько 4 секунд, потім натисніть «Стоп»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "录音中——请继续说约4秒,然后点按“停止”。"
          }
        }
      }
    },
    "Voice sample recorded. Re-record to update it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice sample recorded. Re-record to update it."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Sprachprobe aufgenommen. Neu aufnehmen, um sie zu aktualisieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Muestra de voz grabada. Vuelve a grabar para actualizarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Échantillon vocal enregistré. Réenregistrez pour le mettre à jour."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Campione vocale registrato. Registra di nuovo per aggiornarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "音声サンプルを録音しました。更新するには録音し直してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "음성 샘플이 녹음되었습니다. 업데이트하려면 다시 녹음하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Amostra de voz gravada. Regrave para atualizá-la."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Образец голоса записан. Перезапишите, чтобы обновить."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Зразок голосу записано. Перезапишіть, щоб оновити."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "已录制语音样本。重新录制可更新。"
          }
        }
      }
    },
    "No crew voices yet. Add each person on the headset so their transmissions can be told apart from ATC.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No crew voices yet. Add each person on the headset so their transmissions can be told apart from ATC."
          }
        },
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Noch keine Crew-Stimmen. Füge jede Person mit Headset hinzu, damit ihre Funksprüche von der Flugsicherung unterschieden werden können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aún no hay voces de la tripulación. Añade a cada persona con auriculares para distinguir sus transmisiones de las del ATC."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aucune voix d’équipage pour l’instant. Ajoutez chaque personne au casque pour distinguer ses transmissions de celles du contrôle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ancora nessuna voce dell’equipaggio. Aggiungi ogni persona con la cuffia per distinguere le sue trasmissioni da quelle dell’ATC."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "クルーの音声はまだありません。ヘッドセットを着けている各人を追加すると、その送信をATCと区別できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "아직 승무원 음성이 없습니다. 헤드셋을 착용한 각 사람을 추가하면 해당 송신을 ATC와 구분할 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ainda sem vozes da tripulação. Adicione cada pessoa com fone para distinguir as transmissões dela das do ATC."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Голосов экипажа пока нет. Добавьте каждого в гарнитуре, чтобы отличать их передачи от диспетчера."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Голосів екіпажу ще немає. Додайте кожного в гарнітурі, щоб відрізняти їхні передачі від диспетчера."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "尚无机组语音。添加每位戴耳机的人员,即可将其通话与空管区分开。"
          }
        }
      }
    },
